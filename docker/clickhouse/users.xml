<?xml version="1.0"?>
<!--
  users.xml — Definição de usuários e perfis do ClickHouse
  Montado em: /etc/clickhouse-server/users.d/custom.xml
  Sobrescreve apenas os campos definidos aqui (merge com users padrão).
-->
<clickhouse>
    <users>
        <!-- Usuário principal da aplicação -->
        <clickhouse>
            <!-- Senha em texto simples (apenas dev local) -->
            <password>clickhouse</password>

            <!-- Redes permitidas: qualquer host dentro da Docker network -->
            <networks>
                <ip>::/0</ip>
            </networks>

            <!-- Perfil de configurações -->
            <profile>default</profile>

            <!-- Quota -->
            <quota>default</quota>

            <!-- Acesso a todos os bancos -->
            <access_management>1</access_management>
        </clickhouse>
    </users>

    <profiles>
        <default>
            <!-- Limites de segurança para queries exploratórias -->
            <max_memory_usage>10000000000</max_memory_usage>
            <max_execution_time>300</max_execution_time>
            <max_rows_to_read>1000000000</max_rows_to_read>
            <use_uncompressed_cache>0</use_uncompressed_cache>
            <load_balancing>random</load_balancing>
        </default>

        <readonly>
            <readonly>1</readonly>
        </readonly>
    </profiles>

    <quotas>
        <default>
            <interval>
                <duration>3600</duration>
                <queries>0</queries>
                <errors>0</errors>
                <result_rows>0</result_rows>
                <read_rows>0</read_rows>
                <execution_time>0</execution_time>
            </interval>
        </default>
    </quotas>
</clickhouse>
