# ════════════════════════════════════════════════════════════════════
# .env.example — Template de variáveis de ambiente
# NUNCA commitar o arquivo .env com valores reais!
# Copie este arquivo: cp .env.example .env
# ════════════════════════════════════════════════════════════════════

# ─── ClickHouse ──────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=clickhouse
CLICKHOUSE_DATABASE=analytics

# ─── PostgreSQL (Metastore Airflow + Superset) ────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow

# ─── Apache Airflow ───────────────────────────────────────────────────
# Gerar com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=GERAR_COM_COMANDO_ACIMA
AIRFLOW_SECRET_KEY=dev-secret-key-change-in-production
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@dev.local

# ─── Apache Superset ─────────────────────────────────────────────────
# Gerar com: python -c "import secrets; print(secrets.token_hex(32))"
SUPERSET_SECRET_KEY=GERAR_COM_COMANDO_ACIMA
SUPERSET_ADMIN_USER=admin
SUPERSET_ADMIN_PASSWORD=admin
SUPERSET_ADMIN_EMAIL=admin@dev.local

# ─── Redis ────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ─── Notificações (opcional) ──────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
SMTP_HOST=smtp.empresa.com
SMTP_PORT=587
SMTP_USER=bi@empresa.com
SMTP_PASSWORD=sua-senha-smtp

# ─── Fontes de Dados Externas (preencher por fonte) ──────────────────
# ERP
ERP_DB_HOST=erp-db.empresa.com
ERP_DB_PORT=5432
ERP_DB_USER=readonly_user
ERP_DB_PASSWORD=senha-readonly
ERP_DB_NAME=erp_producao

# CRM API
CRM_API_URL=https://api.crm.empresa.com/v1
CRM_API_KEY=sua-api-key-aqui
CRM_API_SECRET=seu-api-secret-aqui

# ─── Ambiente ────────────────────────────────────────────────────────
ENV=local
# Opções: local | staging | production
LOG_LEVEL=INFO
